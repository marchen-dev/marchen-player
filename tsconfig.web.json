{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "moduleResolution": "Bundler",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@main/*": ["src/main/*"],
      "@pkg": ["./package.json"],
      "@marchen/electron-ipc/*": ["packages/electron-ipc/src/*"],
      "@marchen/shared/*": ["packages/shared/src/*"],
      "@marchen/player-core": ["packages/player-core/src/index.ts"],
      "@marchen/player-core/*": ["packages/player-core/src/*"]
    },
    "strict": true,
    "noUnusedLocals": false
  },
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/main/ipc/**/*",
    "packages/electron-ipc/src/**/*",
    "packages/shared/src/**/*",
    "packages/player-core/src/**/*",
    "types/**/*.d.ts",
    "src/env.ts"
  ]
}
