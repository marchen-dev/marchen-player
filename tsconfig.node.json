{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "moduleResolution": "Bundler",
    "paths": {
      "@pkg": ["./package.json"],
      "@main/*": ["src/main/*"],
      "@marchen/electron-ipc/*": ["packages/electron-ipc/src/*"],
      "@marchen/shared/*": ["packages/shared/src/*"]
    },
    "types": ["electron-vite/node"]
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "types/**/*.d.ts",
    "src/shared/src/**/*",
    "packages/electron-ipc/src/**/*",
    "packages/shared/src/**/*"
  ]
}
