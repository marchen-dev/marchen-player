  /**
   * 文件总长度，单位为Byte。
   */
  fileSize: number

  /**
   * 32位整数的视频时长，单位为秒。默认为0。
   */
  videoDuration?: number

  /**
   * 匹配模式。
   * 可选值: 'hashAndFileName', 'fileNameOnly', 'hashOnly'
   */
  matchMode?: 'hashAndFileName' | 'fileNameOnly' | 'hashOnly'
}

// 定义 MatchResultV2 接口
export interface MatchResultV2 {
  /**
   * 弹幕库ID
