import type { ReponseBaseModel } from './base'

/**
 * 视频文件匹配请求模型
 */
export interface MatchVideoRequestModel {
  /**
   * 视频文件名，不包含文件夹名称和扩展名，特殊字符需进行转义。
   */
  fileName: string

  /**
   * 文件前16MB (16x1024x1024 Byte) 数据的32位MD5结果，不区分大小写。
   */
